# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Database (Supabase Postgres, EU region, transaction pooler) ---
# Get this from Supabase → Project Settings → Database → Connection string → "Transaction"
# Must be the pooler URL on port 6543 (Railway cannot reach the direct IPv6 endpoint)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# --- Supabase Auth (frontend + magic-link callback) ---
# Project Settings → API
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...

# --- App ---
APP_ENV=development
PUBLIC_BASE_URL=http://localhost:8000
SESSION_SECRET=change-me-to-a-long-random-string

# --- Stripe (added in session 9) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- PostHog (frontend snippet uses these) ---
POSTHOG_PUBLIC_KEY=phc_...
POSTHOG_HOST=https://eu.posthog.com
